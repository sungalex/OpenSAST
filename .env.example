# aiSAST 환경변수 예시 — 복사 후 값을 수정하세요
OPENSAST_DEBUG=false

# 데이터베이스
OPENSAST_DATABASE_URL=postgresql+psycopg2://aisast:aisast@localhost:5432/aisast

# Redis · Celery
OPENSAST_REDIS_URL=redis://localhost:6379/0
OPENSAST_CELERY_BROKER_URL=redis://localhost:6379/1
OPENSAST_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MinIO (소스/리포트 저장소)
OPENSAST_MINIO_ENDPOINT=localhost:9000
OPENSAST_MINIO_ACCESS_KEY=minioadmin
OPENSAST_MINIO_SECRET_KEY=minioadmin
OPENSAST_MINIO_BUCKET=aisast-sources
OPENSAST_MINIO_SECURE=false

# 인증
OPENSAST_SECRET_KEY=change-me-in-production-please-use-at-least-32-chars
OPENSAST_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 최초 부트스트랩 관리자 — 운영 환경에서는 반드시 변경하세요
OPENSAST_BOOTSTRAP_ADMIN_EMAIL=admin@aisast.local
OPENSAST_BOOTSTRAP_ADMIN_PASSWORD=aisast-admin
OPENSAST_BOOTSTRAP_ADMIN_DISPLAY_NAME=aiSAST Admin

# LLM
OPENSAST_LLM_PROVIDER=ollama         # ollama | anthropic | noop
OPENSAST_OLLAMA_HOST=http://localhost:11434
OPENSAST_OLLAMA_MODEL=gemma2:9b
OPENSAST_ANTHROPIC_API_KEY=
OPENSAST_ANTHROPIC_MODEL=claude-opus-4-6

# 엔진 바이너리 경로 (PATH 에 있으면 그대로 사용)
OPENSAST_OPENGREP_BIN=semgrep
OPENSAST_BANDIT_BIN=bandit
OPENSAST_ESLINT_BIN=eslint
OPENSAST_GOSEC_BIN=gosec
OPENSAST_SPOTBUGS_BIN=spotbugs
OPENSAST_CODEQL_BIN=codeql
