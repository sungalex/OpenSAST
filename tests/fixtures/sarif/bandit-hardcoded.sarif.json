{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "bandit",
          "version": "1.7.8",
          "rules": [
            {
              "id": "B105",
              "name": "Hardcoded password string",
              "shortDescription": { "text": "SR2-2 하드코딩된 비밀번호" },
              "properties": {
                "tags": ["security", "CWE-259", "mois-SR2-2"],
                "cwe": "CWE-259"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "B105",
          "level": "warning",
          "message": { "text": "Possible hardcoded password: 'DB_PASSWORD'" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/config.py" },
                "region": { "startLine": 8, "startColumn": 1 }
              }
            }
          ]
        }
      ]
    }
  ]
}
