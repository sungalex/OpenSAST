{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "gosec",
          "version": "2.19.0",
          "rules": [
            {
              "id": "G204",
              "name": "Audit use of command execution",
              "shortDescription": { "text": "SR1-2 OS 명령어 삽입" },
              "properties": {
                "tags": ["security", "CWE-78", "mois-SR1-2"],
                "cwe": "CWE-78"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "G204",
          "level": "error",
          "message": { "text": "Subprocess launched with variable: exec.Command(userInput)" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "cmd/handler.go" },
                "region": { "startLine": 55, "startColumn": 3 }
              }
            }
          ]
        }
      ]
    }
  ]
}
