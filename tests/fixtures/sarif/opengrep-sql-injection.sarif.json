{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "version": "1.70.0",
          "rules": [
            {
              "id": "mois-sr1-1-python-sql-fstring",
              "name": "SQL Injection via f-string",
              "shortDescription": { "text": "SR1-1 SQL 삽입" },
              "properties": {
                "tags": ["security", "CWE-89", "mois-SR1-1"],
                "cwe": "CWE-89"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "mois-sr1-1-python-sql-fstring",
          "level": "error",
          "message": { "text": "SQL Injection detected: user input interpolated into SQL query via f-string" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/db.py" },
                "region": { "startLine": 42, "startColumn": 5 }
              }
            }
          ]
        }
      ]
    }
  ]
}
