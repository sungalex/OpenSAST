      },
      "results": [
        {
          "ruleId": "no-unsanitized/property",
          "level": "error",
          "message": { "text": "Unsafe assignment to innerHTML: user-controlled data flows into DOM property" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/components/SearchResult.js" },
                "region": { "startLine": 24, "startColumn": 9 }
