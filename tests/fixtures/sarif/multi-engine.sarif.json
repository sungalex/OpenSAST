{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "version": "1.70.0",
          "rules": [
            {
              "id": "mois-sr1-1-python-sql-fstring",
              "name": "SQL Injection via f-string",
              "shortDescription": { "text": "SR1-1 SQL 삽입" },
              "properties": {
                "tags": ["security", "CWE-89", "mois-SR1-1"],
                "cwe": "CWE-89"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "mois-sr1-1-python-sql-fstring",
          "level": "error",
          "message": { "text": "SQL Injection detected via f-string interpolation" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/db.py" },
                "region": { "startLine": 42, "startColumn": 5 }
              }
            }
          ]
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "bandit",
          "version": "1.7.8",
          "rules": [
            {
              "id": "B303",
              "name": "Use of insecure MD5 hash function",
              "shortDescription": { "text": "SR2-4 약한 암호화 알고리즘 사용" },
              "properties": {
                "tags": ["security", "CWE-327", "mois-SR2-4"],
                "cwe": "CWE-327"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "B303",
          "level": "warning",
          "message": { "text": "Use of insecure hash function: hashlib.md5()" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/crypto_utils.py" },
                "region": { "startLine": 15, "startColumn": 10 }
              }
            }
          ]
        }
      ]
    }
  ]
}
